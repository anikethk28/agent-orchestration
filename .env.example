# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Supervisor model (high-capability for planning)
SUPERVISOR_MODEL=claude-sonnet-4-6
# Specialist model (fast + capable)
SPECIALIST_MODEL=gpt-4o-mini
# Reviewer model
REVIEWER_MODEL=claude-haiku-4-5-20251001

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_orchestration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_orchestration

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=agent_memory

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agent-orchestration

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production
DEBUG=true

# HITL
HITL_CONFIDENCE_THRESHOLD=0.6
HITL_REVIEW_TIMEOUT_SECONDS=300

# Tool rate limits (requests per minute)
WEB_SEARCH_RPM=10
CODE_EXEC_TIMEOUT_SECONDS=30
